WEBHOOK_URL=https://your-n8n-instance.example/webhook/your-id
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-publishable-key

# Stripe paywall — €9.99/month subscription (test keys for local dev, live in prod).
# Payment Link URL is public; the secret key and service-role key are server-only —
# never prefix them with NEXT_PUBLIC_.
NEXT_PUBLIC_STRIPE_PAYMENT_LINK=https://buy.stripe.com/test_your-link-id
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
# Supabase service-role key — bypasses RLS, used only to store the Stripe customer id.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
